{
  "expo": {
    "name": "Vinyas Sathi",
    "slug": "VinyasApp",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vinyasapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.VinyasApp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#070a13",
          "image": "./assets/images/splashscreen_image.png",
          "resizeMode": "contain",
          "imageWidth": 200,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Vinyas App to access your camera to scan Sync ID QR codes.",
          "barcodeScannerEnabled": true
        }
      ],
      [
        "expo-navigation-bar",
        {
          "hidden": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "expo-navigation-bar": {
        "hidden": true
      },
      "eas": {
        "projectId": "3ee08cef-4eaf-492a-9a07-012ba2ce4dce"
      }
    },
    "owner": "kishlay-at-code",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3ee08cef-4eaf-492a-9a07-012ba2ce4dce"
    }
  }
}
